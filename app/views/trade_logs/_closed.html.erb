<%# locals: (closed_positions:) %>

<div class="bg-container rounded-xl border border-alpha-black-25 shadow-border-xs">
  <% if closed_positions.empty? %>
    <div class="p-8 text-center text-sm text-secondary"><%= t(".empty") %></div>
  <% else %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-xs uppercase text-secondary border-b border-alpha-black-50">
            <th class="text-left font-medium px-4 py-2.5"><%= t(".col_period") %></th>
            <th class="text-left font-medium px-4 py-2.5"><%= t(".col_account") %></th>
            <th class="text-left font-medium px-4 py-2.5"><%= t(".col_security") %></th>
            <th class="text-right font-medium px-4 py-2.5"><%= t(".col_qty") %></th>
            <th class="text-right font-medium px-4 py-2.5"><%= t(".col_invested") %></th>
            <th class="text-right font-medium px-4 py-2.5"><%= t(".col_proceeds") %></th>
            <th class="text-right font-medium px-4 py-2.5"><%= t(".col_fees") %></th>
            <th class="text-right font-medium px-4 py-2.5"><%= t(".col_net_profit") %></th>
            <th class="text-right font-medium px-4 py-2.5"><%= t(".col_return_pct") %></th>
            <th class="text-right font-medium px-4 py-2.5"><%= t(".col_holding_days") %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-alpha-black-50">
          <% closed_positions.each do |position| %>
            <tr class="hover:bg-container-hover">
              <td class="px-4 py-2.5 whitespace-nowrap text-secondary">
                <%= I18n.l(position.opened_on, format: :default) %> ~ <%= I18n.l(position.closed_on, format: :default) %>
              </td>
              <td class="px-4 py-2.5 whitespace-nowrap text-secondary"><%= position.account.name %></td>
              <td class="px-4 py-2.5 whitespace-nowrap font-medium text-primary"><%= position.security.ticker %></td>
              <td class="px-4 py-2.5 whitespace-nowrap text-right text-primary privacy-sensitive"><%= format_quantity(position.total_qty) %></td>
              <td class="px-4 py-2.5 whitespace-nowrap text-right text-secondary privacy-sensitive"><%= format_money(Money.new(position.total_invested, position.currency)) %></td>
              <td class="px-4 py-2.5 whitespace-nowrap text-right text-secondary privacy-sensitive"><%= format_money(Money.new(position.total_proceeds, position.currency)) %></td>
              <td class="px-4 py-2.5 whitespace-nowrap text-right text-secondary privacy-sensitive"><%= position.total_fees.zero? ? "—" : position.total_fees.to_s("F").sub(/\.?0+\z/, "") %></td>
              <td class="px-4 py-2.5 whitespace-nowrap text-right privacy-sensitive <%= position.net_profit.negative? ? "text-destructive" : "text-success" %>">
                <%= format_money(Money.new(position.net_profit, position.currency)) %>
              </td>
              <td class="px-4 py-2.5 whitespace-nowrap text-right privacy-sensitive <%= position.return_pct.nil? ? "text-secondary" : (position.return_pct.negative? ? "text-destructive" : "text-success") %>">
                <%= position.return_pct ? number_to_percentage(position.return_pct, precision: 2) : "—" %>
              </td>
              <td class="px-4 py-2.5 whitespace-nowrap text-right text-secondary"><%= t(".days", count: position.holding_days) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
