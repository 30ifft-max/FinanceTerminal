<%= content_for :page_title, t(".title") %>

<div class="space-y-4 pb-6 lg:pb-12 flex flex-col">
  <header class="flex justify-between items-center text-primary font-medium">
    <h1 class="text-xl"><%= t(".title") %></h1>
    <%= render DS::Link.new(
      text: t(".new_trade"),
      icon: "plus",
      variant: "primary",
      href: new_trade_path,
      frame: :modal
    ) %>
  </header>

  <% tab_btn_classes = "focus-ring inline-flex justify-center items-center whitespace-nowrap text-sm font-medium px-6 py-1 rounded-md motion-safe:transition-colors motion-safe:duration-200" %>
  <div class="flex bg-surface-inset p-1 rounded-lg max-w-fit">
    <% [ [ "log", t(".tab_log") ], [ "holdings", t(".tab_holdings") ], [ "closed", t(".tab_closed") ] ].each do |id, label| %>
      <%= link_to label, trade_logs_path(tab: id),
            class: class_names(tab_btn_classes, @tab == id ? "tab-item-active text-primary shadow-sm" : "text-secondary hover:bg-surface-inset-hover") %>
    <% end %>
  </div>

  <% case @tab %>
  <% when "log" %>
    <%= render "trade_logs/log", entries: @entries, pagy: @pagy %>
  <% when "holdings" %>
    <div class="bg-container rounded-xl border border-secondary p-8 text-center text-sm text-secondary">
      <%= t(".holdings_coming_soon") %>
    </div>
  <% when "closed" %>
    <div class="bg-container rounded-xl border border-secondary p-8 text-center text-sm text-secondary">
      <%= t(".closed_coming_soon") %>
    </div>
  <% end %>
</div>
