<%# locals: (form:) %>
<%
  start_value = @q[:start_date].presence
  start_y, start_m, start_d = (start_value || "").split("-")
  start_y = start_y.presence&.slice(2..) || ""
  start_m ||= ""
  start_d ||= ""

  end_value = @q[:end_date].presence
  end_y, end_m, end_d = (end_value || "").split("-")
  end_y = end_y.presence&.slice(2..) || ""
  end_m ||= ""
  end_d ||= ""

  segment_classes = "border border-secondary rounded-lg bg-container-inset py-2.5 px-2 text-sm text-primary text-center focus-visible:ring-2 focus-visible:ring-alpha-black-300"
%>
<div class="flex flex-col w-[420px]">
  <%= form.hidden_field :date_preset_label, value: @q[:date_preset_label], data: { date_range_preset_target: "presetLabel" } %>
  <div class="flex border-b border-secondary">
    <%# Left: preset buttons %>
    <div class="w-36 shrink-0 border-r border-secondary p-3 space-y-1">
      <p class="text-xs font-semibold text-secondary mb-2"><%= t("transactions.searches.filters.date_filter.range_title", default: "日期范围") %></p>
      <% [
        [ t("transactions.searches.filters.date_filter.preset_7d",  default: "过去7天"),  "过去7天",  7,  "days"       ],
        [ t("transactions.searches.filters.date_filter.preset_14d", default: "过去14天"), "过去14天", 14, "days"       ],
        [ t("transactions.searches.filters.date_filter.preset_30d", default: "过去30天"), "过去30天", 30, "days"       ],
        [ t("transactions.searches.filters.date_filter.preset_this_month", default: "本月"), "本月", 0, "this_month" ],
        [ t("transactions.searches.filters.date_filter.preset_last_month", default: "上月"), "上月", 0, "last_month" ],
        [ t("transactions.searches.filters.date_filter.preset_this_year",  default: "今年"), "今年", 0, "this_year"  ],
        [ t("transactions.searches.filters.date_filter.preset_last_year",  default: "去年"), "去年", 0, "last_year"  ],
      ].each do |label, preset_label, amount, kind| %>
        <button type="button"
          class="block w-full text-left px-2 py-1.5 text-sm rounded-md text-secondary hover:text-primary hover:bg-container-inset-hover transition-colors"
          data-action="date-range-preset#apply"
          data-date-range-preset-amount-param="<%= amount %>"
          data-date-range-preset-kind-param="<%= kind %>"
          data-date-range-preset-label-param="<%= preset_label %>">
          <%= label %>
        </button>
      <% end %>
    </div>

    <%# Right: precise date inputs %>
    <div class="grow p-3 space-y-3">
      <div>
        <div class="flex items-center justify-between mb-1">
          <label class="text-xs font-medium text-secondary"><%= t("transactions.searches.filters.date_filter.start_date") %></label>
          <button type="button" class="text-xs text-link hover:underline" data-action="date-range-preset#clearStart">
            <%= t("transactions.searches.filters.date_filter.clear", default: "清除") %>
          </button>
        </div>
        <div class="flex items-center gap-1">
          <input type="text" inputmode="numeric" maxlength="2" placeholder="YY" autocomplete="off" value="<%= start_y %>"
            data-date-range-preset-target="startYear"
            data-action="keydown->date-range-preset#handleSegmentKeydown input->date-range-preset#handleSegmentInput"
            data-date-range-preset-group-param="start" data-date-range-preset-field-param="year"
            class="w-10 <%= segment_classes %>">
          <span class="text-secondary">-</span>
          <input type="text" inputmode="numeric" maxlength="2" placeholder="MM" autocomplete="off" value="<%= start_m %>"
            data-date-range-preset-target="startMonth"
            data-action="keydown->date-range-preset#handleSegmentKeydown input->date-range-preset#handleSegmentInput"
            data-date-range-preset-group-param="start" data-date-range-preset-field-param="month"
            class="w-12 <%= segment_classes %>">
          <span class="text-secondary">-</span>
          <input type="text" inputmode="numeric" maxlength="2" placeholder="DD" autocomplete="off" value="<%= start_d %>"
            data-date-range-preset-target="startDay"
            data-action="keydown->date-range-preset#handleSegmentKeydown input->date-range-preset#handleSegmentInput"
            data-date-range-preset-group-param="start" data-date-range-preset-field-param="day"
            class="w-12 <%= segment_classes %>">
        </div>
        <%= form.hidden_field :start_date, value: start_value, data: { date_range_preset_target: "startDate" } %>
      </div>
      <div>
        <div class="flex items-center justify-between mb-1">
          <label class="text-xs font-medium text-secondary"><%= t("transactions.searches.filters.date_filter.end_date") %></label>
          <button type="button" class="text-xs text-link hover:underline" data-action="date-range-preset#clearEnd">
            <%= t("transactions.searches.filters.date_filter.clear", default: "清除") %>
          </button>
        </div>
        <div class="flex items-center gap-1">
          <input type="text" inputmode="numeric" maxlength="2" placeholder="YY" autocomplete="off" value="<%= end_y %>"
            data-date-range-preset-target="endYear"
            data-action="keydown->date-range-preset#handleSegmentKeydown input->date-range-preset#handleSegmentInput"
            data-date-range-preset-group-param="end" data-date-range-preset-field-param="year"
            class="w-10 <%= segment_classes %>">
          <span class="text-secondary">-</span>
          <input type="text" inputmode="numeric" maxlength="2" placeholder="MM" autocomplete="off" value="<%= end_m %>"
            data-date-range-preset-target="endMonth"
            data-action="keydown->date-range-preset#handleSegmentKeydown input->date-range-preset#handleSegmentInput"
            data-date-range-preset-group-param="end" data-date-range-preset-field-param="month"
            class="w-12 <%= segment_classes %>">
          <span class="text-secondary">-</span>
          <input type="text" inputmode="numeric" maxlength="2" placeholder="DD" autocomplete="off" value="<%= end_d %>"
            data-date-range-preset-target="endDay"
            data-action="keydown->date-range-preset#handleSegmentKeydown input->date-range-preset#handleSegmentInput"
            data-date-range-preset-group-param="end" data-date-range-preset-field-param="day"
            class="w-12 <%= segment_classes %>">
        </div>
        <%= form.hidden_field :end_date, value: end_value, data: { date_range_preset_target: "endDate" } %>
      </div>
    </div>
  </div>

  <%# Bottom bar %>
  <div class="flex justify-between items-center gap-2 p-3">
    <button type="button" class="text-sm text-secondary hover:text-primary" data-action="date-range-preset#clearAll">
      <%= t("transactions.searches.filters.date_filter.clear_all", default: "清除") %>
    </button>
    <div class="flex items-center gap-2">
      <%= render DS::Button.new(text: t("transactions.searches.menu.cancel"), type: "button", variant: "ghost", size: :sm, data: { action: "DS--popover#close" }) %>
      <%= render DS::Button.new(text: t("transactions.searches.menu.apply"), type: :submit, size: :sm) %>
    </div>
  </div>
</div>
