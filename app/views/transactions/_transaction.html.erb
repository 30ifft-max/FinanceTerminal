<%# locals: (entry:, balance_trend: nil, view_ctx: "global", in_split_group: false) %>

<% transaction = entry.entryable %>
<% transaction_security_logo_url = transaction.activity_security&.display_logo_url %>
<% has_tags = transaction.tags.any? %>
<% has_notes = entry.notes.present? %>
<% has_lock = entry.protected_from_sync? && !entry.excluded? %>

<%= turbo_frame_tag dom_id(entry) do %>
  <%= turbo_frame_tag dom_id(transaction) do %>
    <div class="group flex lg:grid lg:grid-cols-12 items-center text-primary text-sm font-medium px-3 py-2 lg:px-4 lg:py-2.5 border-b border-secondary <%= "pl-8 lg:pl-12" if in_split_group %>">

      <%# === Name column (3 cols) === %>
      <div class="pr-4 lg:pr-2 flex items-center gap-3 lg:gap-3 lg:col-span-3 grow lg:grow-0 min-w-0">
        <div class="flex md:hidden items-center gap-1 col-span-2 relative shrink-0">
          <%= render "categories/badge_mobile", category: transaction.category %>
          <% if transaction_security_logo_url.present? %>
            <%= image_tag Setting.transform_brand_fetch_url(transaction_security_logo_url),
                class: "w-5 h-5 rounded-full absolute -bottom-1 -right-1 border border-secondary pointer-events-none",
                loading: "lazy" %>
          <% elsif transaction.merchant&.logo_url.present? %>
            <%= image_tag Setting.transform_brand_fetch_url(transaction.merchant.logo_url),
                class: "w-5 h-5 rounded-full absolute -bottom-1 -right-1 border border-secondary pointer-events-none",
                loading: "lazy" %>
          <% end %>
        </div>

        <div class="max-w-full min-w-0 <%= "opacity-50 text-secondary" if entry.excluded %>">
          <div class="flex items-center gap-1 min-w-0">
            <div class="truncate flex-shrink">
              <% if transaction.transfer? %>
                <%= link_to(
                      entry.name,
                      transaction.transfer.present? ? transfer_path(transaction.transfer) : entry_path(entry),
                      data: { turbo_frame: "drawer", turbo_prefetch: false },
                      class: "hover:underline"
                    ) %>
              <% else %>
                <%= link_to(
                      entry.name,
                      in_split_group ? entry_path(entry, grouped: true) : entry_path(entry),
                      data: { turbo_frame: "drawer", turbo_prefetch: false },
                      class: "hover:underline"
                    ) %>
              <% end %>
            </div>

            <div class="flex items-center gap-1 flex-shrink-0">
              <% if transaction.one_time? %>
                <span class="text-orange-500" title="One-time <%= entry.amount.negative? ? "income" : "expense" %> (excluded from averages)">
                  <%= icon "asterisk", size: "sm", color: "current" %>
                </span>
              <% end %>

              <% if transaction.pending? %>
                <%= render DS::Pill.new(
                  label: t("transactions.transaction.pending"),
                  tone: :neutral, marker: false, icon: "clock",
                  title: t("transactions.transaction.pending_tooltip")
                ) %>
              <% end %>

              <% if transaction.has_potential_duplicate? %>
                <% if transaction.low_confidence_duplicate? %>
                  <%= render DS::Pill.new(
                    label: t("transactions.transaction.review_recommended"),
                    tone: :neutral, marker: false, icon: "help-circle",
                    title: t("transactions.transaction.review_recommended_tooltip")
                  ) %>
                <% else %>
                  <%= render DS::Pill.new(
                    label: t("transactions.transaction.possible_duplicate"),
                    tone: :warning, marker: false, icon: "alert-triangle",
                    title: t("transactions.transaction.potential_duplicate_tooltip")
                  ) %>
                <% end %>
              <% end %>

              <% if @split_parent_entry_ids ? @split_parent_entry_ids.include?(entry.id) : entry.split_parent? %>
                <%= render DS::Pill.new(
                  label: t("transactions.transaction.split"),
                  tone: :neutral, marker: false, icon: "split",
                  title: t("transactions.transaction.split_tooltip")
                ) %>
              <% end %>
              <% if entry.split_child? && !in_split_group %>
                <span class="text-secondary" title="<%= t("transactions.transaction.split_child_tooltip") %>">
                  <%= icon "corner-down-right", size: "sm", color: "current" %>
                </span>
              <% end %>

              <% if transaction.transfer.present? %>
                <%= render "transactions/transfer_match", transaction: transaction %>
              <% end %>
            </div>
          </div>

          <%# Mobile-only: show merchant/category below name %>
          <div class="text-secondary text-xs font-normal lg:hidden">
            <div class="flex min-w-0 items-center gap-1">
              <%= render "categories/category_name_mobile", transaction: transaction %>
              <% if transaction.merchant&.present? %>
                <span class="min-w-0 truncate">• <%= transaction.merchant.name %></span>
              <% end %>
              <span>• <%= entry.account.name %></span>
            </div>
          </div>
        </div>
      </div>

      <%# === Indicators column (1 col = 3 fixed sub-slots: tags | notes | lock) === %>
      <div class="hidden lg:grid grid-cols-[14px_16px_16px] gap-x-1.5 items-center justify-center col-span-1">
        <%# — Tag dots: 1=●  2=●●  3=▲  4=⁞⁞ — %>
        <div class="flex items-center justify-center">
          <% if has_tags %>
            <% tag_list = transaction.tags.first(4) %>
            <div class="relative group/tag cursor-default">
              <% case tag_list.size %>
              <% when 1 %>
                <span class="w-2 h-2 rounded-full block" style="background-color: <%= tag_list[0].color.presence || "#10A861" %>"></span>
              <% when 2 %>
                <div class="flex gap-0.5">
                  <% tag_list.each do |tag| %>
                    <span class="w-2 h-2 rounded-full block" style="background-color: <%= tag.color.presence || "#10A861" %>"></span>
                  <% end %>
                </div>
              <% when 3 %>
                <div class="flex flex-col items-center gap-0.5">
                  <span class="w-2 h-2 rounded-full block" style="background-color: <%= tag_list[0].color.presence || "#10A861" %>"></span>
                  <div class="flex gap-0.5">
                    <span class="w-2 h-2 rounded-full block" style="background-color: <%= tag_list[1].color.presence || "#10A861" %>"></span>
                    <span class="w-2 h-2 rounded-full block" style="background-color: <%= tag_list[2].color.presence || "#10A861" %>"></span>
                  </div>
                </div>
              <% else %>
                <div class="flex flex-col items-center gap-0.5">
                  <div class="flex gap-0.5">
                    <span class="w-2 h-2 rounded-full block" style="background-color: <%= tag_list[0].color.presence || "#10A861" %>"></span>
                    <span class="w-2 h-2 rounded-full block" style="background-color: <%= tag_list[1].color.presence || "#10A861" %>"></span>
                  </div>
                  <div class="flex gap-0.5">
                    <span class="w-2 h-2 rounded-full block" style="background-color: <%= tag_list[2].color.presence || "#10A861" %>"></span>
                    <span class="w-2 h-2 rounded-full block" style="background-color: <%= tag_list[3].color.presence || "#10A861" %>"></span>
                  </div>
                </div>
              <% end %>
              <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 px-3 py-2 rounded-lg bg-gray-800 text-white text-xs opacity-0 pointer-events-none group-hover/tag:opacity-100 transition-opacity duration-100 z-10 w-max max-w-44">
                <div class="space-y-1">
                  <% transaction.tags.each do |tag| %>
                    <div class="flex items-center gap-1.5">
                      <span class="w-2 h-2 rounded-full shrink-0" style="background-color: <%= tag.color.presence || "#10A861" %>"></span>
                      <span><%= tag.name %></span>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>

        <%# — Note icon — %>
        <div class="flex items-center justify-center">
          <% if has_notes %>
            <div class="relative group/note cursor-default">
              <span class="flex items-center justify-center w-4 h-4 rounded text-secondary transition-all duration-100 hover:bg-white/10 hover:text-primary">
                <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14 1H2a1 1 0 0 0-1 1v12l3-2h10a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1Z" />
                  <path d="M5 5h6M5 8h4" />
                </svg>
              </span>
              <div class="absolute top-1/2 -translate-y-1/2 left-full ml-2 px-3 py-2 rounded-lg bg-gray-800 text-white text-xs font-normal opacity-0 pointer-events-none group-hover/note:opacity-100 transition-opacity duration-100 z-10 w-60 whitespace-normal leading-relaxed">
                <%= entry.notes.truncate(200) %>
              </div>
            </div>
          <% end %>
        </div>

        <%# — Sync lock — %>
        <div class="flex items-center justify-center">
          <% if has_lock %>
            <div class="relative group/lock cursor-default">
              <span class="flex items-center justify-center w-4 h-4 rounded text-secondary transition-all duration-100 hover:bg-white/10 hover:text-primary">
                <%= icon "lock", size: "xs", color: "current" %>
              </span>
              <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 px-3 py-2 rounded-lg bg-gray-800 text-white text-xs font-medium whitespace-nowrap opacity-0 pointer-events-none group-hover/lock:opacity-100 transition-opacity duration-100 z-10">
                <%= t("entries.protection.tooltip") %>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <%# === Merchant column (2 cols, desktop only) === %>
      <div class="hidden lg:flex min-w-0 items-center col-span-2">
        <% if transaction.transfer? %>
          <span class="text-secondary text-xs truncate">
            <%= transaction.loan_payment? ? t("transactions.show.loan_payment") : t("transactions.show.transfer") %>
          </span>
        <% elsif transaction.merchant&.present? %>
          <span class="truncate text-secondary"><%= transaction.merchant.name %></span>
        <% else %>
          <span class="text-subdued">—</span>
        <% end %>
      </div>

      <%# === Category column (2 cols, desktop only) === %>
      <div class="hidden md:flex min-w-0 items-center gap-1 col-span-2">
        <% if entry.account.supports_trades? && !transaction.transfer? %>
          <%= render "investment_activity/quick_edit_badge", entry: entry, entryable: transaction %>
        <% else %>
          <%= render "categories/badge", category: transaction.category %>
        <% end %>
      </div>

      <%# === Account column (2 cols, desktop only) === %>
      <div class="hidden lg:flex min-w-0 items-center col-span-2">
        <%= link_to entry.account.name,
            account_path(entry.account, tab: "transactions"),
            data: { turbo_frame: "_top" },
            class: "truncate text-secondary hover:underline" %>
      </div>

      <%# === Amount column (2 cols) === %>
      <div class="shrink-0 col-span-4 lg:col-span-2 ml-auto flex items-center justify-end gap-2 <%= "opacity-50" if entry.excluded %>">
        <span class="privacy-sensitive <%= entry.amount.negative? ? "text-green-600" : "text-red-400" %>">
          <% if transaction.transfer? && view_ctx == "global" %>
            +/- <%= format_money(entry.amount_money.abs, unit: "") %>
          <% else %>
            <%= format_money(-entry.amount_money, unit: "") %>
          <% end %>
        </span>
        <span class="text-secondary text-xs"><%= entry.currency %></span>
      </div>
    </div>
  <% end %>
<% end %>
