<% unless @embedded_in_tab %>
  <%= content_for :page_title, t(".page_title") %>
  <%= content_for :page_actions do %>
    <% if @rules.any? %>
      <%= render DS::Menu.new do |menu| %>
        <% menu.with_item(
          variant: "button",
          text: t("rules.clear_ai_cache.button"),
          href: clear_ai_cache_rules_path,
          icon: "refresh-cw",
          method: :post,
          confirm: CustomConfirm.new(
            title: t("rules.clear_ai_cache.confirm_title"),
            body: t("rules.clear_ai_cache.confirm_body"),
            btn_text: t("rules.clear_ai_cache.confirm_button")
          )) %>
        <% menu.with_item(
          variant: "button",
          text: t(".delete_all_rules"),
          href: destroy_all_rules_path,
          icon: "trash-2",
          method: :delete,
          confirm: CustomConfirm.for_resource_deletion("all rules", high_severity: true)) %>
      <% end %>
      <%= render DS::Link.new(
        text: t("rules.apply_all.button"),
        variant: "secondary",
        href: confirm_all_rules_path,
        icon: "play",
        frame: :modal
      ) %>
    <% end %>
    <%= render DS::Link.new(
      text: t(".new_rule"),
      variant: "primary",
      href: new_rule_path(resource_type: "transaction"),
      icon: "plus",
      frame: :modal
    ) %>
  <% end %>
<% end %>

<%= turbo_frame_tag "rules_tab_panel" do %>
<div class="max-w-4xl mx-auto w-full">
  <div class="bg-container rounded-xl shadow-border-xs p-4">
  <% if @rules.any? %>
    <div class="flex justify-between items-center px-2 py-2 text-xs uppercase">
      <div class="flex items-center gap-1.5 font-medium text-secondary">
        <p><%= t(".rules_heading") %></p>
        <span class="text-subdued">&middot;</span>
        <p><%= @rules.count %></p>
      </div>
      <div class="flex items-center gap-2">
        <div class="flex items-center gap-0.5">
          <span class="text-secondary"><%= t(".sort_by") %></span>
          <%= form_with url: rules_path, method: :get, local: true, class: "flex items-center", data: { controller: "auto-submit-form" } do |form| %>
            <%= form.select :sort_by,
                      options_for_select([[t(".sort_name"), "name"], [t(".sort_updated_at"), "updated_at"]], @sort_by),
                      {},
                      class: "min-w-0 w-auto bg-transparent rounded border-none cursor-pointer text-primary uppercase text-xs pr-5",
                      data: { auto_submit_form_target: "auto", autosubmit_trigger_event: "change" } %>
            <%= form.hidden_field :direction, value: @direction %>
          <% end %>
          <%= render DS::Link.new(
            href: rules_path(direction: @direction == "asc" ? "desc" : "asc", sort_by: @sort_by),
            variant: "icon",
            icon: "arrow-up-down",
            size: :sm,
            title: t(".toggle_sort_direction")
          ) %>
        </div>
        <% if @embedded_in_tab %>
          <%= render DS::Link.new(
            text: t(".new_rule"),
            variant: "primary",
            href: new_rule_path(resource_type: "transaction"),
            icon: "plus",
            size: :sm,
            frame: :modal
          ) %>
        <% end %>
      </div>
    </div>
    <div class="flex flex-col">
      <%= render partial: "rule", collection: @rules, spacer_template: "shared/ruler" %>
    </div>
  <% else %>
    <div class="flex justify-center items-center py-20">
      <div class="text-center flex flex-col items-center max-w-[500px]">
        <p class="text-sm text-primary font-medium mb-1"><%= t(".no_rules_title") %></p>
        <p class="text-sm text-secondary mb-4"><%= t(".no_rules_description") %></p>
        <div class="flex items-center gap-2">
          <%= render DS::Link.new(
            text: t(".new_rule"),
            variant: "primary",
            href: new_rule_path(resource_type: "transaction"),
            icon: "plus",
            frame: :modal
          ) %>
        </div>
      </div>
    </div>
  <% end %>
  </div>

  <!-- Recent Runs Section -->
  <% if @recent_runs.any? %>
    <div class="mt-6 bg-container rounded-xl shadow-border-xs p-4">
      <div class="mb-4">
        <h2 class="text-primary text-lg font-medium mb-1"><%= t("rules.recent_runs.title") %></h2>
        <p class="text-sm text-secondary"><%= t("rules.recent_runs.description") %></p>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-surface border-b border-primary">
            <tr>
              <th class="px-2 py-1.5 text-left text-xs font-medium text-secondary uppercase tracking-wider whitespace-nowrap">
                <%= t("rules.recent_runs.columns.date") %>
              </th>
              <th class="px-2 py-1.5 text-left text-xs font-medium text-secondary uppercase tracking-wider whitespace-nowrap">
                <%= t("rules.recent_runs.columns.time") %>
              </th>
              <th class="px-2 py-1.5 text-center text-xs font-medium text-secondary uppercase tracking-wider whitespace-nowrap">
                <%= t("rules.recent_runs.columns.execution_type") %>
              </th>
              <th class="px-2 py-1.5 text-center text-xs font-medium text-secondary uppercase tracking-wider whitespace-nowrap">
                <%= t("rules.recent_runs.columns.status") %>
              </th>
              <th class="px-2 py-1.5 text-left text-xs font-medium text-secondary uppercase tracking-wider whitespace-nowrap">
                <%= t("rules.recent_runs.columns.rule_name") %>
              </th>
              <th class="w-px px-1.5 py-1.5 text-center text-xs font-medium text-secondary uppercase whitespace-nowrap">
                <%= t("rules.recent_runs.columns.transactions_counts.queued") %>
              </th>
              <th class="w-px px-1.5 py-1.5 text-center text-xs font-medium text-secondary uppercase whitespace-nowrap">
                <%= t("rules.recent_runs.columns.transactions_counts.processed") %>
              </th>
              <th class="w-px px-1.5 py-1.5 text-center text-xs font-medium text-secondary uppercase whitespace-nowrap">
                <%= t("rules.recent_runs.columns.transactions_counts.modified") %>
              </th>
              <th class="w-px px-1.5 py-1.5 text-center text-xs font-medium text-secondary uppercase whitespace-nowrap">
                <%= t("rules.recent_runs.columns.transactions_counts.blocked", default: "Blocked") %>
              </th>
            </tr>
          </thead>
          <tbody class="divide-y divide-alpha-black-200 theme-dark:divide-alpha-white-200">
            <% @recent_runs.each do |run| %>
              <tr class="<%= "bg-red-tint-5 theme-dark:bg-red-tint-10" if run.failed? %>">
                <td class="px-2 py-1.5 text-sm text-primary whitespace-nowrap">
                  <%= run.executed_at.strftime("%Y-%m-%d") %>
                </td>
                <td class="px-2 py-1.5 text-sm text-primary whitespace-nowrap">
                  <%= run.executed_at.strftime("%H:%M") %>
                </td>
                <td class="px-2 py-1.5 text-sm text-primary text-center">
                  <span class="inline-flex items-center px-2 py-1 rounded-md text-xs font-medium <%= run.execution_type == "manual" ? "bg-blue-50 text-blue-700 theme-dark:bg-blue-950/30 theme-dark:text-blue-400" : "bg-purple-50 text-purple-700 theme-dark:bg-purple-950/30 theme-dark:text-purple-400" %>">
                    <%= t("rules.recent_runs.execution_types.#{run.execution_type}") %>
                  </span>
                </td>
                <td class="px-2 py-1.5 text-sm text-center">
                  <div class="flex items-center justify-center gap-2">
                    <% if run.pending? %>
                      <%= render DS::Pill.new(label: t("rules.recent_runs.statuses.#{run.status}"), tone: :warning, marker: false) %>
                    <% elsif run.success? %>
                      <%= render DS::Pill.new(label: t("rules.recent_runs.statuses.#{run.status}"), tone: :success, marker: false) %>
                    <% else %>
                      <%= render DS::Pill.new(label: t("rules.recent_runs.statuses.#{run.status}"), tone: :error, marker: false) %>
                    <% end %>
                    <% if run.failed? && run.error_message.present? %>
                      <div data-controller="tooltip" data-tooltip-content-value="<%= run.error_message %>">
                        <%= icon("info", size: "sm", color: "destructive") %>
                      </div>
                    <% end %>
                  </div>
                </td>
                <td class="px-2 py-1.5 text-sm text-primary">
                  <%= run.rule_name.presence || run.rule&.name.presence || t("rules.recent_runs.unnamed_rule") %>
                </td>
                <td class="w-px px-1.5 py-1.5 text-sm text-primary text-center tabular-nums"><%= number_with_delimiter(run.transactions_queued) %></td>
                <td class="w-px px-1.5 py-1.5 text-sm text-primary text-center tabular-nums"><%= number_with_delimiter(run.transactions_processed) %></td>
                <td class="w-px px-1.5 py-1.5 text-sm text-primary text-center tabular-nums"><%= number_with_delimiter(run.transactions_modified) %></td>
                <td class="w-px px-1.5 py-1.5 text-sm text-primary text-center tabular-nums"><%= number_with_delimiter(run.transactions_blocked) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @pagy.pages > 1 %>
        <div class="mt-4">
          <%= render "shared/pagination", pagy: @pagy %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
<% end %>
